{
  "crons": [
    {
      "path": "/api/cron/confirm-settlements",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/void-postponed",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}